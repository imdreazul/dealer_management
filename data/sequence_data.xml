<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Dealer Application Sequence -->
        <record id="seq_dealership_application" model="ir.sequence">
            <field name="name">Dealership Application</field>
            <field name="code">dealership.application</field>
            <field name="prefix">DA/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Dealership Contract Sequence -->
        <record id="seq_dealership_contract" model="ir.sequence">
            <field name="name">Dealership Contract</field>
            <field name="code">dealership.contract</field>
            <field name="prefix">DC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
