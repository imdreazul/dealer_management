<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_application_submitted" model="mail.template">
            <field name="name">Dealer Application: Submitted</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="subject">Your Dealer Application [{{ object.ref_code }}] Has Been Received</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted) }}</field>
            <field name="body_html" type="html">
<div style="margin:0px;padding:0px;font-family:Arial,sans-serif;">
    <div style="background:#1a73e8;padding:20px 30px;">
        <h2 style="color:#fff;margin:0;">Dealer Application Received</h2>
    </div>
    <div style="padding:20px 30px;background:#f9f9f9;">
        <p>Dear <strong><t t-out="object.name or ''"/></strong>,</p>
        <p>Thank you for submitting your dealer application. We have received your request and our team will review it shortly.</p>
        <table style="width:100%;border-collapse:collapse;margin:16px 0;">
            <tr>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><strong>Reference Code</strong></td>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><t t-out="object.ref_code or ''"/></td>
            </tr>
            <tr>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><strong>Submitted On</strong></td>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><t t-out="object.submitted_on or ''"/></td>
            </tr>
            <tr>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><strong>Status</strong></td>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;">Submitted – Under Review</td>
            </tr>
        </table>
        <p>You can track your application status using your reference code: <strong><t t-out="object.ref_code or ''"/></strong></p>
        <p style="margin-top:20px;">
            <a t-attf-href="{{ object.get_base_url() }}/dealer-status/{{ object.ref_code }}"
               style="background:#1a73e8;color:#fff;padding:10px 24px;text-decoration:none;border-radius:4px;">
                Track Application
            </a>
        </p>
        <hr/>
        <p style="color:#888;font-size:12px;">If you have questions you can reply to this email.</p>
    </div>
</div>
            </field>
        </record>

        <record id="mail_template_application_pending" model="mail.template">
            <field name="name">Dealer Application: Pending – More Info Required</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="subject">Action Required: Your Dealer Application [{{ object.ref_code }}]</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted) }}</field>
            <field name="body_html" type="html">
<div style="margin:0px;padding:0px;font-family:Arial,sans-serif;">
    <div style="background:#f9a825;padding:20px 30px;">
        <h2 style="color:#fff;margin:0;">Additional Information Required</h2>
    </div>
    <div style="padding:20px 30px;background:#f9f9f9;">
        <p>Dear <strong><t t-out="object.name or ''"/></strong>,</p>
        <p>Your dealer application <strong><t t-out="object.ref_code or ''"/></strong> is currently on hold. Our team requires additional information before we can proceed.</p>
        <p>Please log in to your account or reply to this email with the requested information.</p>
        <p style="margin-top:20px;">
            <a t-attf-href="{{ object.get_base_url() }}/dealer-status/{{ object.ref_code }}"
               style="background:#f9a825;color:#fff;padding:10px 24px;text-decoration:none;border-radius:4px;">
                View Application
            </a>
        </p>
    </div>
</div>
            </field>
        </record>

        <record id="mail_template_application_approved" model="mail.template">
            <field name="name">Dealer Application: Approved – Welcome!</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="subject">Congratulations! Your Dealer Application [{{ object.ref_code }}] is Approved</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted) }}</field>
            <field name="body_html" type="html">
<div style="margin:0px;padding:0px;font-family:Arial,sans-serif;">
    <div style="background:#2e7d32;padding:20px 30px;">
        <h2 style="color:#fff;margin:0;">🎉 Welcome to Our Dealer Network!</h2>
    </div>
    <div style="padding:20px 30px;background:#f9f9f9;">
        <p>Dear <strong><t t-out="object.name or ''"/></strong>,</p>
        <p>We are thrilled to inform you that your dealer application has been <strong>approved</strong>. You are now an official dealer!</p>
        <table style="width:100%;border-collapse:collapse;margin:16px 0;">
            <tr>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><strong>Dealer Reference</strong></td>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><t t-out="object.ref_code or ''"/></td>
            </tr>
            <tr>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><strong>Approved On</strong></td>
                <td style="padding:8px;border:1px solid #ddd;background:#fff;"><t t-out="object.approved_on or ''"/></td>
            </tr>
        </table>
        <p>You can now access your <strong>Dealer Profile</strong> on our website using your registered email.</p>
        <p style="margin-top:20px;">
            <a t-attf-href="{{ object.get_base_url() }}/dealer-profile"
               style="background:#2e7d32;color:#fff;padding:10px 24px;text-decoration:none;border-radius:4px;">
                Go to Dealer Profile
            </a>
        </p>
        <hr/>
        <p style="color:#888;font-size:12px;">Your dealer reference code is: <strong><t t-out="object.ref_code or ''"/></strong>. Keep this for your records.</p>
    </div>
</div>
            </field>
        </record>

        <record id="mail_template_application_declined" model="mail.template">
            <field name="name">Dealer Application: Declined</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="subject">Update on Your Dealer Application [{{ object.ref_code }}]</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted) }}</field>
            <field name="body_html" type="html">
<div style="margin:0px;padding:0px;font-family:Arial,sans-serif;">
    <div style="background:#c62828;padding:20px 30px;">
        <h2 style="color:#fff;margin:0;">Application Status Update</h2>
    </div>
    <div style="padding:20px 30px;background:#f9f9f9;">
        <p>Dear <strong><t t-out="object.name or ''"/></strong>,</p>
        <p>We regret to inform you that your dealer application <strong><t t-out="object.ref_code or ''"/></strong> has not been approved at this time.</p>

        <t t-if="object.decline_reason">
            <p><strong>Reason:</strong> <t t-out="object.decline_reason"/></p>
        </t>

        <p>We encourage you to re-apply in the future. If you believe this decision was made in error, please contact us.</p>
        <p style="color:#888;font-size:12px;">Thank you for your interest in joining our dealer network.</p>
    </div>
</div>
            </field>
        </record>

    </data>
</odoo>