<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Auto-expire dealer contracts -->
        <record id="ir_cron_expire_dealer_contracts" model="ir.cron">
            <field name="name">Dealer Management: Auto-Expire Contracts</field>
            <field name="model_id" ref="dealer_management.model_dealership_contract"/>
            <field name="state">code</field>
            <field name="code">model._check_contract_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
