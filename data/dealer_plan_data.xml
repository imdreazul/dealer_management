<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="dealer_plan_basic" model="dealer.plan">
        <field name="name">Basic Dealer</field>
        <field name="plan_type">service</field>
        <field name="price">500.00</field>
        <field name="validity_months">12</field>
        <field name="sequence">10</field>
        <field name="website_published" eval="True"/>
        <field name="description">&lt;p&gt;Entry-level dealer plan with service-based authorization.&lt;/p&gt;</field>
    </record>
    <record id="dealer_plan_standard" model="dealer.plan">
        <field name="name">Standard Dealer</field>
        <field name="plan_type">showroom</field>
        <field name="price">1500.00</field>
        <field name="validity_months">12</field>
        <field name="sequence">20</field>
        <field name="website_published" eval="True"/>
        <field name="description">&lt;p&gt;Standard showroom dealer plan with full product display rights.&lt;/p&gt;</field>
    </record>
    <record id="dealer_plan_premium" model="dealer.plan">
        <field name="name">Premium Dealer</field>
        <field name="plan_type">both</field>
        <field name="price">3000.00</field>
        <field name="validity_months">12</field>
        <field name="sequence">30</field>
        <field name="website_published" eval="True"/>
        <field name="description">&lt;p&gt;Premium plan covering both service and showroom operations with priority support.&lt;/p&gt;</field>
    </record>
</odoo>
