<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Paper Format -->
    <record id="dealer_report_paperformat" model="report.paperformat">
        <field name="name">Dealer Certificate A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height" eval="False"/>
        <field name="page_width" eval="False"/>
        <field name="orientation">Portrait</field>
        <field name="margin_top">20</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_dealer_certificate" model="ir.actions.report">
        <field name="name">Dealer Certificate</field>
        <field name="model">dealer.dealer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dealer_management.report_dealer_certificate</field>
        <field name="report_file">dealer_management.report_dealer_certificate</field>
        <field name="paperformat_id" ref="dealer_report_paperformat"/>
        <field name="binding_model_id" ref="model_dealer_dealer"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Dealer Application Summary Report -->
    <record id="action_report_dealer_application_summary" model="ir.actions.report">
        <field name="name">Application Summary</field>
        <field name="model">dealer.application</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dealer_management.report_dealer_application_summary</field>
        <field name="report_file">dealer_management.report_dealer_application_summary</field>
        <field name="binding_model_id" ref="model_dealer_application"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Dealer Certificate Template -->
    <template id="report_dealer_certificate">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="text-align:center;border:6px double #2c3e50;padding:48px 40px;min-height:800px;">
                            <div style="margin-bottom:24px;">
                                <h1 style="color:#2c3e50;font-size:32px;letter-spacing:2px;margin-bottom:4px;">
                                    AUTHORIZED DEALER CERTIFICATE
                                </h1>
                                <div style="height:3px;background:linear-gradient(to right,#2c3e50,#3498db,#2c3e50);margin:0 auto;width:80%;"/>
                            </div>

                            <p style="font-size:16px;color:#555;margin:32px 0 8px;">This is to certify that</p>
                            <h2 style="font-size:28px;color:#2c3e50;font-weight:bold;margin:0 0 8px;">
                                <t t-esc="doc.name"/>
                            </h2>
                            <p style="font-size:14px;color:#777;margin-bottom:32px;">
                                <t t-esc="doc.city or ''"/>
                                <t t-if="doc.country_id">, <t t-esc="doc.country_id.name"/></t>
                            </p>

                            <p style="font-size:15px;color:#555;line-height:1.8;">
                                has been duly registered and authorized as an
                            </p>
                            <h3 style="font-size:22px;color:#27ae60;margin:8px 0 32px;font-weight:bold;">
                                <t t-esc="doc.plan_id.name if doc.plan_id else 'Official Dealer'"/>
                            </h3>

                            <table style="width:70%;margin:0 auto 32px;border-collapse:collapse;font-size:14px;">
                                <tr>
                                    <td style="padding:8px;color:#888;text-align:right;width:50%;">Dealer Since:</td>
                                    <td style="padding:8px;font-weight:bold;color:#2c3e50;">
                                        <span t-field="doc.plan_start_date"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:8px;color:#888;text-align:right;">Valid Until:</td>
                                    <td style="padding:8px;font-weight:bold;color:#2c3e50;">
                                        <t t-if="doc.plan_expiry_date">
                                            <span t-field="doc.plan_expiry_date"/>
                                        </t>
                                        <t t-else="">Lifetime</t>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:8px;color:#888;text-align:right;">Contact:</td>
                                    <td style="padding:8px;font-weight:bold;color:#2c3e50;">
                                        <t t-esc="doc.phone or doc.email or 'N/A'"/>
                                    </td>
                                </tr>
                            </table>

                            <div style="margin-top:60px;display:flex;justify-content:space-around;">
                                <div style="text-align:center;">
                                    <div style="border-top:2px solid #2c3e50;width:180px;padding-top:8px;margin:0 auto;">
                                        <p style="margin:0;color:#555;font-size:13px;">Authorized Signatory</p>
                                    </div>
                                </div>
                                <div style="text-align:center;">
                                    <div style="border-top:2px solid #2c3e50;width:180px;padding-top:8px;margin:0 auto;">
                                        <p style="margin:0;color:#555;font-size:13px;">Company Seal</p>
                                    </div>
                                </div>
                            </div>

                            <p style="margin-top:40px;font-size:11px;color:#aaa;">
                                This certificate is issued by <t t-esc="doc.partner_id.company_id.name if doc.partner_id.company_id else 'the Company'"/> and is valid for the period stated above.
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Application Summary Template -->
    <template id="report_dealer_application_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 style="color:#2c3e50;border-bottom:2px solid #2c3e50;padding-bottom:8px;">
                            Dealer Application – <t t-esc="doc.ref_code"/>
                        </h2>
                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                            <tr><td style="padding:6px;width:35%;color:#666;font-weight:bold;">Applicant Name</td><td style="padding:6px;"><t t-esc="doc.name"/></td></tr>
                            <tr style="background:#f8f9fa;"><td style="padding:6px;color:#666;font-weight:bold;">Email</td><td style="padding:6px;"><t t-esc="doc.email"/></td></tr>
                            <tr><td style="padding:6px;color:#666;font-weight:bold;">Phone</td><td style="padding:6px;"><t t-esc="doc.phone"/></td></tr>
                            <tr style="background:#f8f9fa;"><td style="padding:6px;color:#666;font-weight:bold;">Business Name</td><td style="padding:6px;"><t t-esc="doc.company_name"/></td></tr>
                            <tr><td style="padding:6px;color:#666;font-weight:bold;">Plan</td><td style="padding:6px;"><t t-esc="doc.plan_id.name if doc.plan_id else 'N/A'"/></td></tr>
                            <tr style="background:#f8f9fa;"><td style="padding:6px;color:#666;font-weight:bold;">Location</td><td style="padding:6px;"><t t-esc="doc.city or ''"/><t t-if="doc.country_id">, <t t-esc="doc.country_id.name"/></t></td></tr>
                            <tr><td style="padding:6px;color:#666;font-weight:bold;">Space Type</td><td style="padding:6px;"><t t-esc="doc.space_type or 'N/A'"/></td></tr>
                            <tr style="background:#f8f9fa;"><td style="padding:6px;color:#666;font-weight:bold;">Space Area</td><td style="padding:6px;"><t t-esc="str(doc.space_area) + ' sq ft' if doc.space_area else 'N/A'"/></td></tr>
                            <tr><td style="padding:6px;color:#666;font-weight:bold;">Status</td><td style="padding:6px;font-weight:bold;color:#2c3e50;"><t t-esc="doc.state.upper()"/></td></tr>
                            <tr style="background:#f8f9fa;"><td style="padding:6px;color:#666;font-weight:bold;">Submitted On</td><td style="padding:6px;"><span t-field="doc.submission_date"/></td></tr>
                            <t t-if="doc.sale_order_id">
                                <tr><td style="padding:6px;color:#666;font-weight:bold;">Sale Order</td><td style="padding:6px;"><t t-esc="doc.sale_order_id.name"/> – <span t-field="doc.sale_order_id.amount_total"/> <t t-esc="doc.sale_order_id.currency_id.name"/></td></tr>
                            </t>
                        </table>
                        <t t-if="doc.admin_notes">
                            <h4 style="margin-top:24px;color:#2c3e50;">Admin Notes</h4>
                            <p><t t-esc="doc.admin_notes"/></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
