<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Portal users can only read/write their own application -->
        <record id="rule_dealership_application_portal_own" model="ir.rule">
            <field name="name">Dealer Application: Portal Users – Own Only</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Dealer Users (internal) can read all, Managers can do everything -->
        <record id="rule_dealership_application_user_all" model="ir.rule">
            <field name="name">Dealer Application: Dealer Users – Read All</field>
            <field name="model_id" ref="dealer_management.model_dealership_application"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('dealer_management.group_dealer_user'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Contract portal rule – dealer can read own contracts -->
        <record id="rule_dealership_contract_portal_own" model="ir.rule">
            <field name="name">Dealer Contract: Portal Users – Own Only</field>
            <field name="model_id" ref="dealer_management.model_dealership_contract"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

    </data>
</odoo>
