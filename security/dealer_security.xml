<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module Category -->
        <record id="module_category_dealer_management" model="ir.module.category">
            <field name="name">Dealer Management</field>
            <field name="description">Manage dealer applications, contracts, and portal access.</field>
            <field name="sequence">100</field>
        </record>

        <!-- Dealer User Group -->
        <record id="group_dealer_user" model="res.groups">
            <field name="name">Dealer User</field>
            <field name="category_id" ref="module_category_dealer_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view dealer applications and contracts. Cannot approve.</field>
        </record>

        <!-- Dealer Manager Group -->
        <record id="group_dealer_manager" model="res.groups">
            <field name="name">Dealer Manager</field>
            <field name="category_id" ref="module_category_dealer_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dealer_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Can create, approve, and manage all dealer applications and contracts.</field>
        </record>

    </data>
</odoo>
