<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         CONTRACT FORM VIEW
    ═══════════════════════════════════════════════════ -->
    <record id="view_dealership_contract_form" model="ir.ui.view">
        <field name="name">dealership.contract.form</field>
        <field name="model">dealership.contract</field>
        <field name="arch" type="xml">
            <form string="Dealership Contract">
                <header>
                    <button name="action_activate"
                            string="Activate Contract"
                            type="object"
                            class="btn-primary"
                            groups="dealer_management.group_dealer_manager"
                            invisible="state != 'draft'"/>
                    <button name="action_terminate"
                            string="Terminate"
                            type="object"
                            class="btn-danger"
                            groups="dealer_management.group_dealer_manager"
                            invisible="state != 'active'"/>
                    <button name="action_expire"
                            string="Mark Expired"
                            type="object"
                            groups="dealer_management.group_dealer_manager"
                            invisible="state not in ('draft', 'active')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <field name="currency_id" invisible="1"/>

                    <div class="oe_title">
                        <label for="name" string="Contract Reference"/>
                        <h1><field name="name" readonly="state != 'draft'"/></h1>
                    </div>
                    <group>
                        <group string="Dealer Information">
                            <field name="application_id" readonly="state != 'draft'"/>
                            <field name="dealer_name" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="created_on" readonly="1"/>
                        </group>
                        <group string="Contract Period">
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date"/>
                            <field name="termination_date" invisible="state != 'terminated'"/>
                            <field name="sale_price_limit" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sale Orders" name="sale_orders">
                            <field name="contract_line_ids">
                                <tree editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>

                                    <field name="sale_order_id"/>
                                    <field name="sale_order_reference" readonly="1"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="total_days" readonly="1"/>
                                    <field name="amount_total" widget="monetary" readonly="1"/>
                                    <field name="status" readonly="1"/>
                                    <field name="state"/>
                                    <field name="notes" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Summary" name="summary">
                            <group>
                                <group>
                                    <field name="sale_order_count" string="Total Orders"/>
                                    <field name="total_sales" widget="monetary" string="Total Sales Amount"/>
                                </group>
                            </group>
                            <field name="notes" string="Notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         CONTRACT TREE VIEW
    ═══════════════════════════════════════════════════ -->
    <record id="view_dealership_contract_tree" model="ir.ui.view">
        <field name="name">dealership.contract.tree</field>
        <field name="model">dealership.contract</field>
        <field name="arch" type="xml">
            <tree string="Dealer Contracts"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('expired', 'terminated')"
                  decoration-warning="state == 'draft'">
                <field name="name"/>
                <field name="dealer_name"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="sale_price_limit" widget="monetary"/>
                <field name="total_sales" widget="monetary"/>
                <field name="sale_order_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state in ('expired', 'terminated')"
                       decoration-warning="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         CONTRACT SEARCH VIEW
    ═══════════════════════════════════════════════════ -->
    <record id="view_dealership_contract_search" model="ir.ui.view">
        <field name="name">dealership.contract.search</field>
        <field name="model">dealership.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="name"/>
                <field name="dealer_name"/>
                <field name="partner_id"/>
                <filter name="filter_active" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_expired" string="Expired" domain="[('state', '=', 'expired')]"/>
                <filter name="filter_terminated" string="Terminated" domain="[('state', '=', 'terminated')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Dealer" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         CONTRACT WINDOW ACTIONS
    ═══════════════════════════════════════════════════ -->
    <record id="action_dealership_contract" model="ir.actions.act_window">
        <field name="name">Dealer Contracts</field>
        <field name="res_model">dealership.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_dealership_contract_search"/>
    </record>

</odoo>
