<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reject Wizard -->
    <record id="view_dealer_reject_wizard_form" model="ir.ui.view">
        <field name="name">dealer.reject.wizard.form</field>
        <field name="model">dealer.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Application">
                <div class="modal-header">
                    <h4 class="modal-title text-danger">
                        <i class="fa fa-times-circle me-2"/>Reject Dealer Application
                    </h4>
                </div>
                <group>
                    <field name="application_id" invisible="1"/>
                    <field name="rejection_reason" widget="text"
                           placeholder="Provide a clear reason. This will be included in the rejection email sent to the applicant."/>
                </group>
                <footer>
                    <button string="Confirm Rejection" type="object"
                            name="action_confirm_reject" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dealer_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Application</field>
        <field name="res_model">dealer.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_application_id': active_id}</field>
    </record>

    <!-- Proposal Wizard -->
    <record id="view_dealer_proposal_wizard_form" model="ir.ui.view">
        <field name="name">dealer.proposal.wizard.form</field>
        <field name="model">dealer.proposal.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Proposal">
                <div class="modal-header">
                    <h4 class="modal-title text-success">
                        <i class="fa fa-file-text me-2"/>Create &amp; Send Dealer Proposal
                    </h4>
                </div>
                <group>
                    <group string="Application">
                        <field name="application_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group string="Proposal Details">
                        <field name="plan_id"/>
                        <field name="price" widget="monetary"/>
                        <field name="product_id" readonly="1"/>
                    </group>
                </group>
                <group>
                    <field name="note" widget="text"
                           placeholder="Optional proposal terms, conditions or notes for the applicant..."/>
                </group>
                <footer>
                    <button string="Create Sale Order &amp; Send Email" type="object"
                            name="action_send_proposal" class="btn-success"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dealer_proposal_wizard" model="ir.actions.act_window">
        <field name="name">Send Proposal</field>
        <field name="res_model">dealer.proposal.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_application_id': active_id}</field>
    </record>

</odoo>
