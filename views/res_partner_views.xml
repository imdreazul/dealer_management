<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend res.partner form to show dealer info -->
    <record id="view_partner_dealer_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.dealer.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(dealer_management.action_dealership_application_approved)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-handshake-o"
                        invisible="not is_dealer"
                        groups="dealer_management.group_dealer_manager">
                    <span class="o_stat_text">Dealer</span>
                </button>
            </xpath>
            <xpath expr="//field[@name='website']" position="after">
                <field name="is_dealer"
                       groups="dealer_management.group_dealer_manager"/>
                <field name="dealer_since"
                       invisible="not is_dealer"
                       groups="dealer_management.group_dealer_manager"/>
                <field name="geo_lat"
                       invisible="not is_dealer"
                       groups="dealer_management.group_dealer_manager"/>
                <field name="geo_lng"
                       invisible="not is_dealer"
                       groups="dealer_management.group_dealer_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
