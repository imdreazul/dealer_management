<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_dealer" model="ir.ui.view">
        <field name="name">res.config.settings.dealer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">

                <app data-string="Dealer Management" string="Dealer Management" name="dealer_management">

                    <block title="Integrations" name="dealer_integration_setting_container">

                        <setting id="google_maps_api" string="Google Maps API Key" help="Enter your Google Maps API key for the dealer locator.">

                            <field name="google_maps_api_key"/> </setting>

                    </block>
                </app>

            </xpath>

        </field>
    </record>
</odoo>