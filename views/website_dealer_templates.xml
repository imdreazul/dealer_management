<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══════════════════════════════════════════════════════════
     BECOME A DEALER - Application Form Page
══════════════════════════════════════════════════════════ -->
<template id="website_become_dealer" name="Become a Dealer">
    <t t-call="website.layout">
        <t t-set="title">Become a Dealer</t>
        <div class="o_dealer_page">

            <!-- Hero Banner -->
            <section class="dealer-hero py-5" style="background:linear-gradient(135deg,#2c3e50 0%,#3498db 100%);">
                <div class="container text-center text-white">
                    <h1 class="display-4 fw-bold mb-3">Become a Dealer</h1>
                    <p class="lead mb-0">Partner with us and grow your business. Fill in the form below to get started.</p>
                </div>
            </section>

            <!-- Plans Strip -->
            <section class="bg-light py-4">
                <div class="container">
                    <div class="row justify-content-center g-3">
                        <t t-foreach="plans" t-as="plan">
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100 text-center">
                                    <div class="card-body py-3">
                                        <h5 class="fw-bold text-primary mb-1"><t t-esc="plan.name"/></h5>
                                        <p class="text-muted small mb-1"><t t-esc="dict(plan._fields['plan_type'].selection).get(plan.plan_type, plan.plan_type)"/></p>
                                        <span class="fs-4 fw-bold"><t t-esc="plan.price"/> <small class="fs-6 text-muted"><t t-esc="plan.currency_id.name"/></small></span>
                                        <p class="text-muted small mt-1 mb-0"><t t-esc="plan.validity_months"/> months validity</p>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>

            <!-- Application Form -->
            <section class="py-5">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-lg-9">
                            <div class="card shadow border-0">
                                <div class="card-header bg-dark text-white py-3">
                                    <h4 class="mb-0"><i class="fa fa-file-text me-2"/>Dealer Application Form</h4>
                                </div>
                                <div class="card-body p-4">
                                    <form action="/become-a-dealer/submit" method="post" enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                        <!-- Personal Info -->
                                        <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fa fa-user me-2"/>Personal Information</h5>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                                                <input type="text" name="name" class="form-control"
                                                       t-att-value="values.get('name','')" required="required" placeholder="John Doe"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                                                <input type="email" name="email" class="form-control"
                                                       t-att-value="values.get('email','')" required="required" placeholder="john@example.com"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Phone <span class="text-danger">*</span></label>
                                                <input type="tel" name="phone" class="form-control"
                                                       t-att-value="values.get('phone','')" required="required" placeholder="+880 1XXX XXXXXX"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Business / Shop Name <span class="text-danger">*</span></label>
                                                <input type="text" name="company_name" class="form-control"
                                                       t-att-value="values.get('company_name','')" required="required" placeholder="Your Business Name"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Business Website</label>
                                                <input type="url" name="website_url" class="form-control"
                                                       t-att-value="values.get('website_url','')" placeholder="https://yourbusiness.com"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Select Plan <span class="text-danger">*</span></label>
                                                <select name="plan_id" class="form-select" required="required">
                                                    <option value="">-- Choose a Plan --</option>
                                                    <t t-foreach="plans" t-as="plan">
                                                        <option t-att-value="plan.id">
                                                            <t t-esc="plan.name"/> – <t t-esc="plan.price"/> <t t-esc="plan.currency_id.name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Location -->
                                        <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fa fa-map-marker me-2"/>Location</h5>
                                        <div class="row g-3 mb-3">
                                            <div class="col-12">
                                                <label class="form-label fw-semibold">Street Address</label>
                                                <input type="text" name="street" class="form-control" t-att-value="values.get('street','')" placeholder="House / Road / Area"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">City <span class="text-danger">*</span></label>
                                                <input type="text" name="city" class="form-control" t-att-value="values.get('city','')" required="required" placeholder="Dhaka"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Country</label>
                                                <select name="country_id" id="country_id" class="form-select">
                                                    <option value="">-- Country --</option>
                                                    <t t-foreach="countries" t-as="country">
                                                        <option t-att-value="country.id"><t t-esc="country.name"/></option>
                                                    </t>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">State / Division</label>
                                                <select name="state_id" id="state_id" class="form-select">
                                                    <option value="">-- State --</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">ZIP Code</label>
                                                <input type="text" name="zip_code" class="form-control" t-att-value="values.get('zip_code','')" placeholder="1200"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Latitude</label>
                                                <input type="number" step="0.0000001" name="latitude" id="dealer_lat" class="form-control" t-att-value="values.get('latitude','')" placeholder="23.8103"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Longitude</label>
                                                <input type="number" step="0.0000001" name="longitude" id="dealer_lng" class="form-control" t-att-value="values.get('longitude','')" placeholder="90.4125"/>
                                            </div>
                                            <div class="col-12">
                                                <button type="button" id="btn_detect_location" class="btn btn-outline-secondary btn-sm">
                                                    <i class="fa fa-crosshairs me-1"/>Detect My Location
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Space -->
                                        <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fa fa-building me-2"/>Space Details</h5>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Space Type <span class="text-danger">*</span></label>
                                                <select name="space_type" class="form-select" required="required">
                                                    <option value="shop">Shop</option>
                                                    <option value="office">Office</option>
                                                    <option value="showroom">Showroom</option>
                                                    <option value="warehouse">Warehouse</option>
                                                    <option value="other">Other</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Space Area (sq ft)</label>
                                                <input type="number" name="space_area" class="form-control" placeholder="e.g. 500"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label fw-semibold">Ownership</label>
                                                <select name="space_ownership" class="form-select">
                                                    <option value="">-- Select --</option>
                                                    <option value="owned">Owned</option>
                                                    <option value="rented">Rented</option>
                                                    <option value="leased">Leased</option>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Uploads -->
                                        <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fa fa-paperclip me-2"/>Images &amp; Documents</h5>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Shop / Office Images</label>
                                                <input type="file" name="shop_images" class="form-control" multiple="multiple" accept="image/*"/>
                                                <div class="form-text">Upload photos of your shop or office space (JPG, PNG)</div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Supporting Documents</label>
                                                <input type="file" name="documents" class="form-control" multiple="multiple" accept=".pdf,.doc,.docx"/>
                                                <div class="form-text">Trade license, NID, etc. (PDF, DOC)</div>
                                            </div>
                                        </div>

                                        <div class="d-grid">
                                            <button type="submit" class="btn btn-primary btn-lg">
                                                <i class="fa fa-paper-plane me-2"/>Submit Application
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </t>
</template>

<!-- ══════════════════════════════════════════════════════════
     THANK YOU PAGE
══════════════════════════════════════════════════════════ -->
<template id="website_dealer_thankyou" name="Dealer Application - Thank You">
    <t t-call="website.layout">
        <t t-set="title">Application Submitted</t>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-md-7 text-center">
                        <div class="card shadow border-0 p-5">
                            <div class="mb-4">
                                <i class="fa fa-check-circle text-success" style="font-size:64px;"/>
                            </div>
                            <h2 class="fw-bold mb-3">Application Submitted!</h2>
                            <p class="text-muted mb-4">Thank you for applying. We've received your application and will review it shortly.</p>
                            <t t-if="application">
                                <div class="alert alert-info mb-4">
                                    <p class="mb-1"><strong>Your Reference Code:</strong></p>
                                    <h3 class="fw-bold text-primary mb-1"><t t-esc="application.ref_code"/></h3>
                                    <p class="mb-0 small">A confirmation email has been sent to <strong><t t-esc="application.email"/></strong></p>
                                </div>
                                <a t-att-href="application.get_status_url()" class="btn btn-primary me-2">
                                    <i class="fa fa-search me-1"/>Track My Application
                                </a>
                            </t>
                            <a href="/" class="btn btn-outline-secondary mt-2">
                                <i class="fa fa-home me-1"/>Back to Home
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </t>
</template>

<!-- ══════════════════════════════════════════════════════════
     STATUS SEARCH PAGE
══════════════════════════════════════════════════════════ -->
<template id="website_dealer_status_search" name="Track Dealer Application">
    <t t-call="website.layout">
        <t t-set="title">Track Your Application</t>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card shadow border-0">
                            <div class="card-header bg-dark text-white py-3 text-center">
                                <h4 class="mb-0"><i class="fa fa-search me-2"/>Track Your Application</h4>
                            </div>
                            <div class="card-body p-4">
                                <t t-if="error">
                                    <div class="alert alert-danger"><t t-esc="error"/></div>
                                </t>
                                <p class="text-muted mb-4">Enter your reference code and email to check the status of your application.</p>
                                <form action="/dealer/status/check" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Reference Code</label>
                                        <input type="text" name="ref_code" class="form-control form-control-lg"
                                               placeholder="e.g. DLR/2025/00001" required="required"/>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold">Email Address</label>
                                        <input type="email" name="email" class="form-control form-control-lg"
                                               placeholder="your@email.com" required="required"/>
                                    </div>
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg">
                                            <i class="fa fa-search me-2"/>Check Status
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </t>
</template>

<!-- ══════════════════════════════════════════════════════════
     STATUS VIEW PAGE (with token link)
══════════════════════════════════════════════════════════ -->
<template id="website_dealer_status" name="Dealer Application Status">
    <t t-call="website.layout">
        <t t-set="title">Application Status – <t t-esc="application.ref_code"/></t>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <!-- Status Badge -->
                        <div class="card shadow border-0 mb-4">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="mb-0 fw-bold">Application Status</h4>
                                    <span t-att-class="'badge fs-6 ' + {
                                        'draft': 'bg-secondary',
                                        'under_review': 'bg-info',
                                        'proposal_sent': 'bg-warning text-dark',
                                        'approved': 'bg-success',
                                        'rejected': 'bg-danger',
                                        'cancelled': 'bg-dark',
                                    }.get(application.state, 'bg-secondary')">
                                        <t t-esc="dict(application._fields['state'].selection).get(application.state, application.state)"/>
                                    </span>
                                </div>
                                <p class="text-muted mb-0">Reference: <strong><t t-esc="application.ref_code"/></strong></p>
                            </div>
                        </div>

                        <!-- Progress Steps -->
                        <div class="card shadow border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4">Application Progress</h5>
                                <div class="dealer-progress-steps">
                                    <t t-set="steps" t-value="[
                                        ('draft', 'Submitted', 'fa-paper-plane'),
                                        ('under_review', 'Under Review', 'fa-search'),
                                        ('proposal_sent', 'Proposal Sent', 'fa-file-text'),
                                        ('approved', 'Approved', 'fa-check-circle'),
                                    ]"/>
                                    <div class="d-flex justify-content-between position-relative">
                                        <div class="progress position-absolute w-100" style="top:20px;height:4px;z-index:0;">
                                            <div class="progress-bar bg-success" style="width:100%"/>
                                        </div>
                                        <t t-foreach="steps" t-as="step">
                                            <t t-set="step_states" t-value="['draft','under_review','proposal_sent','approved']"/>
                                            <t t-set="app_state_idx" t-value="step_states.index(application.state) if application.state in step_states else 0"/>
                                            <t t-set="step_idx" t-value="step_states.index(step[0])"/>
                                            <div class="text-center" style="z-index:1;min-width:80px;">
                                                <div t-att-class="'rounded-circle d-inline-flex align-items-center justify-content-center mx-auto ' + ('bg-success text-white' if step_idx &lt;= app_state_idx else 'bg-light text-muted border')"
                                                     style="width:42px;height:42px;font-size:18px;">
                                                    <i t-att-class="'fa ' + step[2]"/>
                                                </div>
                                                <p t-att-class="'small mt-2 mb-0 ' + ('fw-bold text-success' if step_idx == app_state_idx else 'text-muted')">
                                                    <t t-esc="step[1]"/>
                                                </p>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Application Details -->
                        <div class="card shadow border-0 mb-4">
                            <div class="card-header bg-light py-3">
                                <h5 class="mb-0 fw-bold">Application Details</h5>
                            </div>
                            <div class="card-body p-4">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1">Full Name</p>
                                        <p class="fw-semibold mb-0"><t t-esc="application.name"/></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1">Business Name</p>
                                        <p class="fw-semibold mb-0"><t t-esc="application.company_name"/></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1">Plan Applied For</p>
                                        <p class="fw-semibold mb-0"><t t-esc="application.plan_id.name"/></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1">Location</p>
                                        <p class="fw-semibold mb-0"><t t-esc="application.city"/><t t-if="application.country_id">, <t t-esc="application.country_id.name"/></t></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1">Submitted On</p>
                                        <p class="fw-semibold mb-0"><t t-esc="application.submission_date" t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/></p>
                                    </div>
                                    <t t-if="application.sale_order_id">
                                        <div class="col-md-6">
                                            <p class="text-muted small mb-1">Proposal / Order</p>
                                            <p class="fw-semibold mb-0">
                                                <t t-esc="application.sale_order_id.name"/> –
                                                <t t-esc="application.sale_order_id.amount_total"/>
                                                <t t-esc="application.sale_order_id.currency_id.name"/>
                                            </p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Rejection Reason -->
                        <t t-if="application.state == 'rejected' and application.rejection_reason">
                            <div class="alert alert-danger">
                                <h6 class="fw-bold"><i class="fa fa-exclamation-circle me-1"/>Rejection Reason</h6>
                                <p class="mb-0"><t t-esc="application.rejection_reason"/></p>
                            </div>
                        </t>

                        <!-- Approved - Portal Link -->
                        <t t-if="application.state == 'approved'">
                            <div class="alert alert-success text-center">
                                <i class="fa fa-check-circle fa-2x mb-2 d-block"/>
                                <h5 class="fw-bold">You are now an approved dealer!</h5>
                                <a href="/my/dealer/dashboard" class="btn btn-success mt-2">
                                    <i class="fa fa-tachometer me-2"/>Go to Dealer Dashboard
                                </a>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </section>
    </t>
</template>

<!-- ══════════════════════════════════════════════════════════
     FIND A DEALER - Map Page
══════════════════════════════════════════════════════════ -->
<template id="website_find_dealer" name="Find a Dealer">
    <t t-call="website.layout">
        <t t-set="title">Find a Dealer</t>
        <div class="o_dealer_locator_page">
            <section class="dealer-hero py-4" style="background:linear-gradient(135deg,#2c3e50 0%,#3498db 100%);">
                <div class="container text-center text-white">
                    <h1 class="display-5 fw-bold mb-2">Find a Dealer Near You</h1>
                    <p class="lead mb-0">Locate authorized dealers on the map and get directions</p>
                </div>
            </section>

            <section class="py-4">
                <div class="container-fluid px-4">
                    <div class="row g-4">
                        <!-- Sidebar: Dealer List -->
                        <div class="col-lg-4 col-xl-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="mb-3">
                                        <button id="btn_use_my_location" class="btn btn-primary btn-sm w-100 mb-2">
                                            <i class="fa fa-crosshairs me-1"/>Use My Location
                                        </button>
                                        <input type="text" id="dealer_search_input" class="form-control form-control-sm"
                                               placeholder="Search by city or name..."/>
                                    </div>
                                    <div id="dealer_list_container" style="max-height:calc(100vh - 300px);overflow-y:auto;">
                                        <div class="text-center text-muted py-4">
                                            <i class="fa fa-spinner fa-spin fa-2x"/>
                                            <p class="mt-2">Loading dealers...</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Map -->
                        <div class="col-lg-8 col-xl-9">
                            <div id="dealer_map" class="rounded shadow-sm"
                                 style="height:calc(100vh - 200px);min-height:500px;background:#eee;"/>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- Dealer Card Template (hidden, used by JS) -->
        <div id="dealer_card_template" class="d-none">
            <div class="dealer-list-item border rounded p-3 mb-2 cursor-pointer" data-dealer-id="">
                <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                        <h6 class="mb-1 fw-bold dealer-name"></h6>
                        <p class="text-muted small mb-1 dealer-city"></p>
                        <div class="dealer-rating text-warning mb-1"></div>
                        <p class="text-muted small mb-1 dealer-distance"></p>
                    </div>
                </div>
            </div>
        </div>

        <script t-if="gmaps_api_key">
            var GMAPS_API_KEY = '<t t-esc="gmaps_api_key"/>';
        </script>
        <script t-else="">
            var GMAPS_API_KEY = '';
        </script>
    </t>
</template>

</odoo>
