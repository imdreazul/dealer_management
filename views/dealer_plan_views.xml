<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Plan tree -->
    <record id="view_dealer_plan_tree" model="ir.ui.view">
        <field name="name">dealer.plan.tree</field>
        <field name="model">dealer.plan</field>
        <field name="arch" type="xml">
            <tree string="Dealer Plans" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="plan_type"/>
                <field name="price" widget="monetary"/>
                <field name="currency_id" optional="hide"/>
                <field name="validity_months"/>
                <field name="dealer_count"/>
                <field name="website_published"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Plan Form -->
    <record id="view_dealer_plan_form" model="ir.ui.view">
        <field name="name">dealer.plan.form</field>
        <field name="model">dealer.plan</field>
        <field name="arch" type="xml">
            <form string="Dealer Plan">
                <sheet>
<!--                    <div class="oe_button_box" name="button_box">-->
<!--                        <button class="oe_stat_button" type="object" name="action_view_dealers" icon="fa-users" invisible="dealer_count == 0">-->
<!--                            <field name="dealer_count" widget="statinfo" string="Dealers"/>-->
<!--                        </button>-->
<!--                    </div>-->
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active == True"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Plan Name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="plan_type"/>
                            <field name="price"/>
                            <field name="currency_id"/>
                            <field name="validity_months"/>
                        </group>
                        <group>
                            <field name="min_investment"/>
                            <field name="max_investment"/>
                            <field name="product_id"/>
                            <field name="website_published"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Features">
                            <field name="feature_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="included"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Plan Action -->
    <record id="action_dealer_plan" model="ir.actions.act_window">
        <field name="name">Dealer Plans</field>
        <field name="res_model">dealer.plan</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
