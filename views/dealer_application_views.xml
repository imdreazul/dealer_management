<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dealer_application_tree" model="ir.ui.view">
        <field name="name">dealer.application.tree</field>
        <field name="model">dealer.application</field>
        <field name="arch" type="xml">
            <tree string="Dealer Applications" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="state == 'proposal_sent'"
                  decoration-info="state == 'under_review'">
                <field name="ref_code"/>
                <field name="name"/>
                <field name="company_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="plan_id"/>
                <field name="submission_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state in ('proposal_sent','under_review')"
                       decoration-muted="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <record id="view_dealer_application_form" model="ir.ui.view">
        <field name="name">dealer.application.form</field>
        <field name="model">dealer.application</field>
        <field name="arch" type="xml">
            <form string="Dealer Application">

                <field name="sale_order_id" invisible="1"/>
                <field name="dealer_id" invisible="1"/>

                <header>
                    <button name="action_under_review" string="Start Review" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="%(action_dealer_proposal_wizard)d" string="Send Proposal" type="action" class="btn-primary" invisible="state not in ['under_review', 'draft']"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state not in ['under_review', 'proposal_sent']"/>
                    <button name="%(action_dealer_reject_wizard)d" string="Reject" type="action" class="btn-danger" invisible="state in ['approved', 'rejected', 'cancelled']"/>
                    <button name="action_view_sale_order" string="View Proposal" type="object" class="btn-secondary" invisible="not sale_order_id"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ['rejected', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,under_review,proposal_sent,approved"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_sale_order" icon="fa-shopping-cart" invisible="not sale_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Sale Order</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-user" name="action_open_dealer_profile" invisible="not dealer_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Dealer Profile</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="ref_code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Applicant Info">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="company_name"/>
                            <field name="website_url"/>
                            <field name="plan_id"/>
                        </group>
                        <group string="Status &amp; Dates">
                            <field name="submission_date"/>
                            <field name="review_date" invisible="not review_date"/>
                            <field name="approval_date" invisible="not approval_date"/>
                            <field name="partner_id" invisible="not partner_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Location">
                            <group>
                                <group string="Address">
                                    <field name="street"/>
                                    <field name="city"/>
                                    <field name="state_id"/>
                                    <field name="country_id"/>
                                    <field name="zip_code"/>
                                </group>
                                <group string="GPS Coordinates">
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                </group>
                            </group>
                        </page>
                        <page string="Space Details">
                            <group>
                                <field name="space_type"/>
                                <field name="space_area"/>
                                <field name="space_ownership"/>
                            </group>
                        </page>
                        <page string="Images">
                            <field name="shop_image_ids" widget="many2many_binary" string="Shop / Office Images"/>
                        </page>
                        <page string="Documents">
                            <field name="document_ids" widget="many2many_binary" string="Supporting Documents"/>
                        </page>
                        <page string="Admin Notes">
                            <group>
                                <field name="admin_notes" widget="text" placeholder="Internal notes for the review team..."/>
                                <field name="rejection_reason" widget="text" invisible="state != 'rejected'" placeholder="Reason for rejection (will be sent in email)..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_dealer_application_kanban" model="ir.ui.view">
        <field name="name">dealer.application.kanban</field>
        <field name="model">dealer.application</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="ref_code"/>
                <field name="name"/>
                <field name="company_name"/>
                <field name="email"/>
                <field name="plan_id"/>
                <field name="state"/>
                <field name="submission_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="company_name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="ref_code"/>
                                    </small>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-user"/> <field name="name"/></div>
                                <div><i class="fa fa-envelope"/> <field name="email"/></div>
                                <div><i class="fa fa-tag"/> <field name="plan_id"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted">
                                    <field name="submission_date" widget="date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dealer_application_search" model="ir.ui.view">
        <field name="name">dealer.application.search</field>
        <field name="model">dealer.application</field>
        <field name="arch" type="xml">
            <search string="Search Applications">
                <field name="ref_code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="company_name"/>
                <field name="city"/>
                <field name="plan_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Under Review" name="under_review" domain="[('state','=','under_review')]"/>
                <filter string="Proposal Sent" name="proposal_sent" domain="[('state','=','proposal_sent')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Plan" name="groupby_plan" context="{'group_by': 'plan_id'}"/>
                    <filter string="City" name="groupby_city" context="{'group_by': 'city'}"/>
                    <filter string="Submission Date" name="groupby_date" context="{'group_by': 'submission_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dealer_application" model="ir.actions.act_window">
        <field name="name">Dealer Applications</field>
        <field name="res_model">dealer.application</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No dealer applications yet!
            </p>
            <p>Applications submitted from the website will appear here.</p>
        </field>
    </record>
</odoo>