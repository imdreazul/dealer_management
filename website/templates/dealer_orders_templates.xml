<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="inherit_dealer_profile_orders" inherit_id="dealer_management.template_dealer_profile">

        <!-- 1. Add "Create Order" button & Success Alert above the Orders list -->
        <xpath expr="//div[@id='ordersPane']//t[@t-if='not sale_orders']" position="before">
            <div class="p-4 pb-0 d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-bold">My Orders</h5>
                <!-- Trigger Create Modal Button -->
                <button type="button" class="btn btn-primary btn-sm rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#createOrderModal">
                    <i class="fa fa-plus me-1"/> Create Order
                </button>
            </div>

            <!-- Success Alert if redirected from order creation -->
            <t t-if="success">
                <div class="mx-4 alert alert-success alert-dismissible fade show" role="alert" style="border-radius:10px;">
                    <i class="fa fa-check-circle me-2"/> Order successfully created!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </t>
        </xpath>

        <!-- 2. Make Table Rows trigger the View Modal -->
        <xpath expr="//div[@id='ordersPane']//tbody/t/tr" position="replace">
            <tr style="cursor: pointer; transition: background 0.2s;" class="table-hover" data-bs-toggle="modal" t-attf-data-bs-target="#viewOrderModal_{{ order.id }}">
                <td class="px-4 fw-semibold text-primary" t-esc="order.name"/>
                <td>
                    <t t-if="order.date_order">
                        <t t-esc="order.date_order.strftime('%d %b %Y')"/>
                    </t>
                </td>
                <td>
                    <t t-foreach="order.order_line[:2]" t-as="line">
                        <span class="badge bg-light text-dark border me-1 small" t-esc="line.product_id.name"/>
                    </t>
                    <t t-if="len(order.order_line) > 2">
                        <span class="text-muted small">+<t t-esc="len(order.order_line) - 2"/> more</span>
                    </t>
                </td>
                <td class="fw-semibold">
                    <t t-esc="'%.2f' % order.amount_total"/>
                    <small class="text-muted ms-1" t-esc="order.currency_id.symbol"/>
                </td>
                <td>
                    <t t-if="order.state in ['sale', 'done']"><span class="badge bg-success">Confirmed</span></t>
                    <t t-elif="order.state == 'cancel'"><span class="badge bg-danger">Cancelled</span></t>
                    <t t-else=""><span class="badge bg-warning text-dark">Quotation</span></t>
                </td>
            </tr>
        </xpath>

        <!-- 3. Add Pagination below the table -->
        <xpath expr="//div[@id='ordersPane']//div[hasclass('table-responsive')]" position="after">
            <div class="d-flex justify-content-center mt-4 mb-3">
                <t t-call="website.pager"/>
            </div>
        </xpath>

        <!-- 4. Inject Modals at the END of the layout (Outside the tabs to prevent Bootstrap conflict) -->
        <xpath expr="//t[@t-call='website.layout']" position="inside">

            <!-- Explicitly Load Select2 for the Portal -->
            <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
            <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

            <!-- CSS tweaks for Select2 inside Odoo portal -->
            <style>
                .select2-container .select2-selection--single { height: 32px !important; border: 1px solid #dee2e6; border-radius: 0.25rem; }
                .select2-container--default .select2-selection--single .select2-selection__rendered { line-height: 32px !important; font-size: 0.875rem; }
                .select2-container--default .select2-selection--single .select2-selection__arrow { height: 32px !important; }
                .select2-container--open { z-index: 99999 !important; } /* Guarantee dropdown appears above modal */
            </style>

            <!-- CREATE ORDER MODAL -->
            <!-- Note the addition of data-bs-focus="false" here - this fixes the typing issue natively! -->
            <div class="modal fade" id="createOrderModal" data-bs-focus="false" aria-labelledby="createOrderModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content" style="border-radius:14px; border:none;">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold text-primary" id="createOrderModalLabel">
                                <i class="fa fa-shopping-cart me-2"/>Create New Order
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <p class="text-muted small mb-4">Select products and quantities to generate a new order draft.</p>
                            <form action="/dealer-profile/order/submit" method="post" id="dealer_order_form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="line_count" id="line_count" value="1"/>

                                <div class="table-responsive mb-3 border rounded" style="overflow:visible;">
                                    <table class="table table-borderless align-middle mb-0" id="order_lines_table">
                                        <thead class="bg-light border-bottom">
                                            <tr>
                                                <th>Product</th>
                                                <th width="120px">Quantity</th>
                                                <th width="60px" class="text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="order_lines_body">

                                            <!-- HIDDEN TEMPLATE ROW -->
                                            <tr id="row_template" class="border-bottom d-none">
                                                <td>
                                                    <select class="form-select form-select-sm template-select" style="width: 100%;">
                                                        <option value="">-- Select Product --</option>
                                                        <t t-foreach="products" t-as="product">
                                                            <option t-att-value="product.id"><t t-esc="product.display_name"/></option>
                                                        </t>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm qty-input" min="1" value="1"/>
                                                </td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-circle remove-line-btn" style="width:30px; height:30px; padding:0;">
                                                        <i class="fa fa-trash"/>
                                                    </button>
                                                </td>
                                            </tr>

                                            <!-- FIRST ACTIVE ROW -->
                                            <tr id="row_0" class="border-bottom active-row">
                                                <td>
                                                    <select name="product_id_0" class="form-select form-select-sm searchable-select" style="width: 100%;" required="required">
                                                        <option value="">-- Select Product --</option>
                                                        <t t-foreach="products" t-as="product">
                                                            <option t-att-value="product.id"><t t-esc="product.display_name"/></option>
                                                        </t>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" name="qty_0" class="form-control form-control-sm" min="1" value="1" required="required"/>
                                                </td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-circle" disabled="1" style="width:30px; height:30px; padding:0;">
                                                        <i class="fa fa-trash"/>
                                                    </button>
                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <button type="button" id="add_line_btn" class="btn btn-outline-secondary btn-sm rounded-pill">
                                        <i class="fa fa-plus me-1"/> Add Product
                                    </button>
                                    <div>
                                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary px-4 rounded-pill ms-2">
                                            <i class="fa fa-paper-plane me-1"/> Submit
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BULLETPROOF JAVASCRIPT -->
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    let lineCount = 1;
                    const tbody = document.getElementById('order_lines_body');
                    const lineCountInput = document.getElementById('line_count');
                    const addBtn = document.getElementById('add_line_btn');
                    const modalEl = document.getElementById('createOrderModal');

                    // 1. Reusable Select2 Initialization Function
                    function initSelect2(element) {
                        if (window.jQuery &amp;&amp; window.jQuery.fn.select2) {
                            window.jQuery(element).select2({
                                dropdownParent: window.jQuery('#createOrderModal .modal-content'),
                                width: '100%',
                                placeholder: "-- Select Product --"
                            });
                        }
                    }

                    // 2. Initialize FIRST row using Vanilla JS Bootstrap Event Listener
                    // This guarantees it fires exactly when the modal animation finishes
                    if (modalEl) {
                        modalEl.addEventListener('shown.bs.modal', function () {
                            const firstSelect = document.querySelector('#row_0 .searchable-select');

                            // Prevent double-initialization
                            if (firstSelect &amp;&amp; !firstSelect.classList.contains('select2-hidden-accessible')) {
                                initSelect2(firstSelect);
                            }
                        });
                    }

                    // 3. Add New Row Logic
                    if(addBtn &amp;&amp; tbody) {
                        addBtn.addEventListener('click', function() {
                            const template = document.getElementById('row_template');
                            const newRow = template.cloneNode(true);

                            newRow.id = 'row_' + lineCount;
                            newRow.classList.remove('d-none');
                            newRow.classList.add('active-row');

                            const select = newRow.querySelector('.template-select');
                            select.name = 'product_id_' + lineCount;
                            select.classList.remove('template-select');
                            select.classList.add('searchable-select');
                            select.required = true;

                            const input = newRow.querySelector('.qty-input');
                            input.name = 'qty_' + lineCount;
                            input.required = true;

                            const delBtn = newRow.querySelector('.remove-line-btn');
                            delBtn.addEventListener('click', function() {
                                newRow.remove();
                            });

                            tbody.appendChild(newRow);

                            // Initialize Select2 immediately because modal is already open
                            initSelect2(select);

                            lineCount++;
                            lineCountInput.value = lineCount;
                        });
                    }
                });
            </script>
        </xpath>
    </template>
</odoo>